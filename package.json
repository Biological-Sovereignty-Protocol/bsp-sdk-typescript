{
  "name": "@bsp/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Biological Sovereignty Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bsp",
    "biological-sovereignty",
    "longevity",
    "health-data",
    "biomarker",
    "arweave",
    "biohacking",
    "protocol"
  ],
  "author": "Ambrósio Institute",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Biological-Sovereignty-Protocol/bsp-sdk-typescript"
  },
  "homepage": "https://biologicalsovereigntyprotocol.com/developers/sdk-reference",
  "bugs": {
    "url": "https://github.com/Biological-Sovereignty-Protocol/bsp-sdk-typescript/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}