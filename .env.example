# Environment variables for @bsp/sdk

# Your institution's .bsp domain (registered on Aptos)
BSP_IEO_DOMAIN=yourlaboratory.bsp

# Your institution's private key (Ed25519, returned at IEO creation)
# ⚠️  Keep this secret — never commit to version control
BSP_IEO_PRIVATE_KEY=your_private_key_here

# Network environment: mainnet | testnet | local
BSP_NETWORK=testnet

# Registry API URL (default: https://api.biologicalsovereigntyprotocol.com)
# BSP_REGISTRY_URL=https://api.biologicalsovereigntyprotocol.com

# Aptos Move contract address where BSP modules are deployed
# BSP_CONTRACT_ADDRESS=0x...

# Aptos network (mainnet | testnet | devnet | local)
# BSP_APTOS_NETWORK=testnet

# Aptos fullnode URL override (optional)
# BSP_APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1

# Request timeout in milliseconds (default: 30000)
# BSP_TIMEOUT_MS=30000
