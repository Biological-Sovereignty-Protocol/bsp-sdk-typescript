# Environment variables for @bsp/sdk

# Your institution's .bsp domain (registered on Arweave)
BSP_IEO_DOMAIN=yourlaboratory.bsp

# Your institution's private key (Ed25519, returned at IEO creation)
# ⚠️  Keep this secret — never commit to version control
BSP_IEO_PRIVATE_KEY=your_private_key_here

# Network environment: mainnet | testnet | local
BSP_NETWORK=testnet

# Registry API URL (default: https://registry.biologicalsovereigntyprotocol.com)
# BSP_REGISTRY_URL=https://registry.biologicalsovereigntyprotocol.com

# Arweave node URL (default: https://arweave.net)
# BSP_ARWEAVE_NODE=https://arweave.net

# Request timeout in milliseconds (default: 30000)
# BSP_TIMEOUT_MS=30000
